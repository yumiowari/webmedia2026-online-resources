@ARTICLE{Lu2024,
	author = {Lu, Yuantong and Wang, Zhanquan},
	title = {Few Adjustable Parameters Prediction Model Based on Lightweight Prefix-Tuning: Learning Session Dropout Prediction Model Based on Parameter-Efficient Prefix-Tuning},
	year = {2024},
	journal = {Applied Sciences (Switzerland)},
