@CONFERENCE{InfantRaj2024,
	author = {Infant Raj, I. and Pavani, G. and Shukla, Tushar Dhar and Arunadevi, V. and Kavitha, P. and Parida, Prasanta},
	title = {MOOC Learner Performance Prediction with CNN-LSTM Mechanism},
	year = {2024},
	journal = {2024 IEEE Silchar Subsection Conference, SILCON 2024},
	pages = {},
	doi = {10.1109/SILCON63976.2024.10910596},
	url = {https://www.scopus.com/pages/publications/105001376317?origin=resultslist},
	affiliations = {K.Ramakrishnan College of Engineering, Department of Cse, Tamil Nadu, Trichy, India; Velagapudi Ramakrishna Siddhartha Engineering, College-Siddhartha Academy of Higher Education (Deemed to Be University), Department of English, Vijayawada, India; University Institute of Physical Education & Sports, Chandigarh University, Mohali, India; Dr.Mahalingam College of Engineering and Technology, Department of Science and Humanities, Pollachi, India; Nandha Engineering College (Autonomous), Department of English, Erode, India; School of Rural Management, Kiit University, Odisha, Bhubaneswar, India},
	abstract = {Predicting student performance in massive open online courses (MOOCs) is important for instructional outcomes and the development of personalized learning interventions. This study presents a novel approach using Convolutional Neural Networks (CNNs) and Long Short-Term Memory (LSTM) networks to predict student performance in a MOOC environment, collectively referred to as CNN-LSTM trap Using the CNN component of the model is used to extract sequences from student interaction data, e.g. Learning orientation patterns, timing of tasks, and participant considerations. These extracts are then transferred to the LSTM network, which captures time dependence and patterns in student behavior over time. The effectiveness of the CNN-LSTM system is evaluated using traditional methods such as Random Forests using detailed datasets obtained from MOOC platforms including accuracy, precision, recall, and F1 score. Specifically, the CNN-LSTM tool achieves 93.41% accuracy, 87.71% accuracy, 85.42% recall, and 89.06% F1 scores, performing significantly better than the random forest model which achieves about 66% accuracy with different accuracy and recall scores. This study contributes to the advancement of educational research by providing a rigorous framework for student engagement in MOOCs. Insights from this study can inform educators and workshop facilitators to implement, and thus deliver, targeted interventions and individualized learning strategies educational experiences and outcomes have been positive in digital learning environments. Future work includes refining the CNN-LSTM framework, exploring new features, and combining semantic approaches to increase model explicitness and usability in educational settings.  © 2024 IEEE.},
