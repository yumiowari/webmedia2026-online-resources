	url = {https://www.scopus.com/pages/publications/105028495642?origin=resultslist},
	affiliations = {Research and Evaluation Methodology, University of Florida, College of Education, Gainesville, United States; Educational Technology, University of Florida, College of Education, Gainesville, United States},
	abstract = {Learner feedback offers critical insights for improving digital learning platforms, yet analyzing large volumes of unstructured qualitative data remains challenging. Traditional thematic analysis depends on manual coding, which is time-consuming, resource-intensive, and susceptible to human bias. This study introduces CATALYST (Cluster Augmented Thematic Analysis using Locally-deployed Yet Scalable Tool), an automated framework that integrates K-means clustering with small, locally deployable large language models (LLMs) to conduct efficient, privacy-preserving thematic analysis. Using 7,292 learner reviews from Duolingo, CATALYST achieved substantial agreement in theme identification, with inter-LLM consistency closely mirroring human-LLM alignment and surpassing baseline human-coded results. The model generated more granular and interpretable themes, uncovering key factors that influence learner satisfaction, such as engagement, perceived effectiveness, gamification, and technical reliability. Compared to traditional methods, CATALYST markedly reduces manual workload, accelerates analysis, and preserves data confidentiality. These results demonstrate the potential of locally deployed LLMs to advance large-scale qualitative analysis in educational research. Future work should extend CATALYST’s application to diverse textual datasets and further refine methods for balancing automation with theme granularity. © 2026 Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {educational text mining; Large language models; learning feedback; online language learning; thematic analysis},
