	title = {Exploring the Potential of Large Language Models for Estimating the Reading Comprehension Question Difficulty},
	year = {2025},
	journal = {Lecture Notes in Computer Science},
	volume = {15812 LNCS},
	pages = {202 - 213},
	doi = {10.1007/978-3-031-92967-0_14},
