	title = {GNN-driven modeling and prediction of multi-dimensional correlation of international medical education quality based on competence},
	year = {2026},
	journal = {Computers and Education: Artificial Intelligence},
	volume = {10},
	pages = {},
	doi = {10.1016/j.caeai.2026.100582},
