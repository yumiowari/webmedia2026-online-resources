@INPROCEEDINGS{11075311,
  author={Panizales, Warren and Lagunzad, Herminiño and Ferrer, Melvin and Villanueva, Crimgene and Kalaw, Daisy and Garcia, Kris},
  booktitle={2025 16th International Conference on E-Education, E-Business, E-Management and E-Learning (IC4e)}, 
  title={Predicting Student Dropout Rates in Online Education Platforms utilizing Naive Bayes Algorithm}, 
  year={2025},
  volume={},
  number={},
  pages={425-429},
  abstract={High student dropout rates pose a significant challenge to the effectiveness of online education platforms. This study utilizes the Naive Bayes algorithm to predict student dropouts by analyzing data on academic performance, engagement, demographics, and behavior. Key techniques such as SMOTE and Recursive Feature Elimination (RFE) are employed to address class imbalance and enhance model accuracy. The Naive Bayes classifier is optimized using scalable machine learning frameworks, enabling real-time predictions for timely interventions. Evaluation metrics like accuracy, precision, recall, F1-score, and ROC-AUC demonstrate the model's superior performance compared to traditional methods. Results indicate that Naive Bayes effectively identifies at-risk students, providing valuable insights for targeted support strategies. This research advances educational data mining by demonstrating the practical application of Naive Bayes in reducing dropout rates and fostering a more supportive online learning environment.},
  keywords={Measurement;Electronic learning;Accuracy;Education;Machine learning;Real-time systems;Naive Bayes methods;Data mining;Reliability;Mentoring;Student Dropout Prediction;Online Education Platforms;Naive Bayes Algorithm;Educational Data Mining;Machine Learning;Student Retention},
  doi={10.1109/IC4e65071.2025.11075311},
  ISSN={},
  month={April},}@INPROCEEDINGS{10617260,
  author={Murwaningsih, Tri and Sasmini and Rahardjo, Setyo Sri and Suwandi, Sarwiji and Saddhono, Kundharu and Nurhasanah, Farida},
  booktitle={2024 4th International Conference on Advance Computing and Innovative Technologies in Engineering (ICACITE)}, 
  title={A Well Structured Strategy Development via AI Integrated Analytics Systems to Improve Performance of Education}, 
  year={2024},
  volume={},
  number={},
  pages={873-878},
  abstract={Perhaps the two goals that have been most emphatically underscored within the changed landscape of higher education include personalized education and the optimization of student outcomes. Artificial intelligence (AI) thus comes on the horizon as a more decisive force, especially considering the field of learning analytics. This research paper investigates the application of AI-driven learning analytics in universities. The main objective is to clarify if, in fact, it is able to predict students’ performance with more precision and effectiveness than traditional methodologies. This identified the inclination of the present study because of the default limitations in learning analytics that were noticed: the dependence on static and historical data with linear predictive models. The AI model developed by us has been quite successful in predicting at-risk students much earlier in the course, which gives the educators a fair chance for timely interventions. Valuable insights related to factors that most significantly influence student success and, therefore, potentially uncover areas that need pedagogical enhancement are brought to light by further analysis. These findings have several implications. The integration of AI in learning analytic systems thus provides ways through which educational policymakers or university administrators could easily customize the educational strategies according to individual student needs, hence developing a supportive and more efficient learning environment. This would therefore add to a growing pool of empirical evidence that AI has great potential in LA improvement in educational technology.},
  keywords={Measurement;Statistical analysis;Neural networks;Force;Educational technology;Learning (artificial intelligence);Predictive models;AI-driven learning analytics;student performance prediction;universities;artificial intelligence;personalized education;optimization;higher education;pedagogical enhancement;predictive analytics;intervention effectiveness},
  doi={10.1109/ICACITE60783.2024.10617260},
  ISSN={},
  month={May},}@INPROCEEDINGS{11040379,
  author={Arockia Mary, P and K, Umamaheswari and S, Bhushan S and S, Hariharan K and G, Dennish Albert and R, Harivarshan},
  booktitle={2025 3rd International Conference on Artificial Intelligence and Machine Learning Applications Theme: Healthcare and Internet of Things (AIMLA)}, 
  title={Revolutionizing Departmental Management through Intelligent Technology:A Machine Learning Approach to Optimization}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The increasing complexity of academic administration necessitates intelligent automation for Department Management Systems (DMS). Traditional systems rely on manual scheduling, attendance tracking, and student evaluation, which results in inefficiencies, scheduling conflicts, and a lack of real-time analytics. Current solutions lack AI-driven predictive insights, automated timetable generation, biometric-based attendance tracking, and intelligent student performance assessments, which are essential for improving institutional efficiency. This research introduces an AI-powered Department Management System (DMS) integrating machine learning (ML), deep learning, and Role-Based Access Control (RBAC) to automate faculty scheduling, optimize student evaluations, and enhance institutional decision-making. The proposed system includes AI-based Timetable Scheduling, Automated Attendance Tracking using biometric authentication, AI-powered Question Paper Generation, and placement shortlisting with AI-driven resume screening. Additionally, a secure role-based authentication framework ensures data privacy and access control across different user levels. Experimental results demonstrate a 15% reduction in scheduling conflicts, 30% improvement in faculty workload balancing, and 96% accuracy in student performance predictions. Comparative evaluations highlight that the AI-powered model outperforms traditional methods in execution speed, resource utilization, and scalability. The proposed framework reduces administrative workload, improves student engagement, and optimizes placement opportunities. Future enhancements will focus on blockchain-integrated academic records, adaptive AI-based learning analytics, and cloud-based deployment for multi-institutional scalability. By leveraging AI and predictive analytics, this system transforms academic management, ensuring efficiency, accuracy, and automation in higher education institutions.},
  keywords={Access control;Deep learning;Support vector machines;Adaptation models;Accuracy;Scalability;Decision making;Manuals;Transforms;Real-time systems;Machine learning;AI-powered Department Management System;AI-based Timetable Scheduling;Role-Based Access Control (RBAC)},
  doi={10.1109/AIMLA63829.2025.11040379},
  ISSN={},
  month={April},}@INPROCEEDINGS{10859995,
  author={Vijaya Kumar, Nukala and Rafi, Shaik and Mahith, Tumpala and Reddy, D. Venkata and Naik, Kethavath Ravi and Raju, Kolakani},
  booktitle={2024 International Conference on Integrated Intelligence and Communication Systems (ICIICS)}, 
  title={Unveiling Student Success: A Multifaceted Approach with Learning Coefficients and Beyond}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={The student performance is examined in this study using a number of methods of Educational Data Mining (EDM), Clustering and classification techniques are employed to classify the course as well as the performance in the entrance examination. The results obtained show that the Random Forest and XG Boost which are machine learning models outperform traditional methods for predicting student success. Moreover, CNN and LSTM Networks, which are deep learning models, improve prediction accuracy even further. Conducted through metrics like accuracy, precision, recall and Fl-score, this study shows that any form of recognition of the pattern, in this case, the early one, helps to reduce failure rates to considerable extents. The results of this study suggest that there is a potential scope for further improving prediction algorithms and management of educational resources, which are of great relevance to the institutions to further the student success.},
  keywords={Deep learning;Support vector machines;Accuracy;Machine learning algorithms;Predictive models;Nearest neighbor methods;Prediction algorithms;Convolutional neural networks;Long short term memory;Random forests;early detection;data mining;academic performance;non-academic performance student performance prediction;graph mining introduction},
  doi={10.1109/ICIICS63763.2024.10859995},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11196115,
  author={Mary, S. Prince and Gambhir, Vinima and Mahalakshmi, R and Begum, Benazeer and Kala and Mahajan, Shriya},
  booktitle={2025 International Conference on Metaverse and Current Trends in Computing (ICMCTC)}, 
  title={Optimizing Student Engagement Prediction with Machine Learning and Big Data Analytics}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Student engagement involves participation, motivation, and emotional involvement, and has implications for academic performance. Machine learning (ML) can predict student engagement through big data analytics can offer insights for personalized learning and interventions, revealing trends beyond traditional methods. The research investigates the purpose of ML and big data by optimizing the prediction of student engagement. The dataset from the open source is utilized which consists of many academic and behavioral features of students. In the pre-processing phase, the data is normalized with Min-Max, which scales data into the appropriate range to perform the model more effectively. It makes feature extraction using Principal Component Analysis (PCA), which reduces the dimensions of information but keeps vital components of the data. The novel Shark Nose Optimizer tuned-Dynamic Support Vector Regression (SNO-DSVR) approach to increase student engagement predicting accuracy. SNO significantly refines the DSVR model also enhances the optimization as well as the predictive abilities of the method. The efficiency of the method is compared against existing approaches based on the main performance metrics which are accuracy 93.15%, precision 95.00%, recall 94.12%, AUC 97.00%, and log loss 21.40%. The result strongly points to the SNO-DSVR outperforming others in correctly predicting student engagement, indicating the possibility of its implementation in educational analytics for enhanced student outcomes.},
  keywords={Support vector machines;Accuracy;Machine learning;Big Data;Predictive models;Performance metrics;Market research;Feature extraction;Data models;Principal component analysis;Machine Learning (Ml);Big Data;Student Engagement;Prediction},
  doi={10.1109/ICMCTC62214.2025.11196115},
  ISSN={},
  month={April},}@INPROCEEDINGS{11011532,
  author={Rajendran, Vasanth and Besiahgari, Dinesh and Patil, Sachin Chandrakant and Challagulla, Vishnu and Chandrashekaraiah, Manjunath},
  booktitle={2025 International Conference on Data Science, Agents & Artificial Intelligence (ICDSAAI)}, 
  title={Academic Temporal Pattern Mining for Enhanced Student Performance Prediction: A Hybrid Machine Learning Approach}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Predicting student academic performance effectively remains challenging due to the dynamic nature of learning behavior and the complex interplay of factors affecting student success. This paper introduces Academic Temporal Pattern Mining (ATPM), a novel approach that identifies critical time-based patterns in student academic behavior to enhance performance prediction accuracy. Unlike traditional methods that rely on static snapshots of student data, our approach analyzes sequential patterns in study habits, submission timings, and performance trends. Using a UCI Student Performance Dataset of 1,000 undergraduates, we demonstrate that temporal patterns such as assignment submission sequences and grade progression provide crucial predictive insights. Our hybrid model, combining Random Forest for feature stability and XGBoost for capturing non-linear relationships, achieves an accuracy of 87%, representing a 15% improvement over conventional regression-based methods. Moreover, we rigorously evaluate the statistical significance of these gains (p < 0.05) and show an 80% precision threshold for early warning up to three assessment cycles before final grades. This research contributes to educational data mining by offering a practical and scalable framework for temporal pattern analysis that leverages readily available academic data for timely, actionable interventions.},
  keywords={Accuracy;Market research;Stability analysis;Timing;Data mining;Pattern analysis;Random forests;temporal pattern mining;student performance prediction;educational data mining;hybrid machine learning;academic analytics},
  doi={10.1109/ICDSAAI65575.2025.11011532},
  ISSN={},
  month={March},}@INPROCEEDINGS{11229636,
  author={Nugraha, Fiona Maharani and Dewi, Kimberly Kayla and Gunawan, Alexander Agung Santoso and Tedjasulaksana, Jeffrey Junior},
  booktitle={2025 IEEE International Conference on Artificial Intelligence and Mechatronics Systems (AIMS)}, 
  title={Leveraging Regression-Based Machine Learning for Predicting Middle School Student Passing Grades}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Traditional methods of assessing student performance may be time-consuming and lack accuracy, therefore a modern method is needed since education is important for students and lecturers to enhance their academic quality. This research uses an ML model (KNN, Decision Tree, Linear Regression, and Random Forest) for predicting student passing grades using data on student demographics and academic performance. These models used regression techniques to predict middle school student passing grades (G3). The aim on this research is to compare and find which is the best ML model to predict the passing grade in regression schema. The final result shows that the Linear Regression models performs the best, achieving the lowest error rates $(\mathrm{MSE}=3.9934, \mathrm{RMSE}=1.9884, \mathrm{MAE}=1.2022$, $\text{MAPE}= 3.12 \%$) and the highest explanatory power ($\mathbf{R}^{\mathbf{2}}=\mathbf{0 . 8 0 6 7}$). Therefore, Linear Regression can be selected as the most effective model for predicting student passing grades based on academic performance data.},
  keywords={Accuracy;Soft sensors;Linear regression;Predictive models;Nearest neighbor methods;Data models;Reliability;Predictive analytics;Regression tree analysis;Random forests;machine learning;student performance;passing grade;academic success;predictive analytics in education;educational data mining},
  doi={10.1109/AIMS66189.2025.11229636},
  ISSN={},
  month={May},}@INPROCEEDINGS{11442550,
  author={Li, Huilin and Zhou, Yue and Fu, Xiaoqun},
  booktitle={2025 2nd International Conference on Artificial Intelligence and Teacher Education (ICAITE)}, 
  title={Predicting and Real-Time Evaluating the Online Learning Quality of Elementary School Students Based on Ensemble Learning and Clustering}, 
  year={2025},
  volume={},
  number={},
  pages={74-79},
  abstract={With the rapid growth of online education, large volumes of student behavioral data are continuously collected, providing new opportunities for quantitative assessment of learning quality. However, data from elementary students are typically highly heterogeneous, noisy, and incomplete, posing significant challenges for real-time prediction and accurate evaluation. To address these challenges, this study proposes a ClusterConstrained Gradient Boosting Regression Tree (CC-GBRT) model that integrates ensemble learning with clustering constraints for learning quality prediction and dynamic assessment. A Gaussian Copula-based multivariate data simulation method was first employed to construct a statistically consistent and privacy-preserving learning behavior dataset. Subsequently, the K -means algorithm was used to partition the behavioral space, and local regression models were trained within each cluster to capture behavioral diversity and enhance prediction stability and precision. In addition, a dynamic Learning Quality Rating (LQR) indicator was designed to quantify students' engagement and performance variation in real time. Experimental results demonstrate that the proposed CC-GBRT model outperforms traditional methods, reducing the Mean Absolute Error (MAE) and Root Mean Squared Error (RMSE) by approximately 15-17%, and increasing the coefficient of determination ($R^{2}$) by about 2%. Furthermore, the model exhibits strong robustness under noisy data conditions, while the LQR metric achieves a Pearson correlation coefficient of 0.84 with actual academic performance, confirming its reliability in learning quality monitoring and assessment. Overall, this study provides a datadriven and interpretable framework for real-time evaluation of online learning quality, offering methodological insights for the intelligent transformation of basic education.},
  keywords={Trees (botanical);Education;Learning (artificial intelligence);Predictive models;Boosting;Real-time systems;Stability analysis;Ensemble learning;Noise measurement;Regression tree analysis;Ensemble Learning;Gradient Boosting Regression Tree;Educational Data Mining;Online Learning Quality Assessment},
  doi={10.1109/ICAITE68636.2025.11442550},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10957150,
  author={Chouhan, Sandeep and Prakash, S Ashish and Zaheer, Mohammed and Singh, Jobandeep and Sinha, Debasish and Kaur, Mandeep},
  booktitle={2025 International Conference on Automation and Computation (AUTOCOM)}, 
  title={Advanced Learning Platform Integrating AR/VR, AI and Voice Command Technologies for Innovative Educational Experiences}, 
  year={2025},
  volume={},
  number={},
  pages={47-52},
  abstract={This research presents the procedures for designing and implementing a sophisticated learning management system capable of employing augmented reality (AR), virtual reality (VR), artificial intelligence (AI), and voice command technologies to create immersive educational experiences. The developed platform responds to the increasing need for personalized and interactive learning environments that engage students more deeply than traditional methods. With AR and VR, the platform expands the possibilities of visual and experimental learning as students interact with the material not only hands-on but also in a more engaging and three-dimensional way. AI algorithms module the users according to their performance and behaviours, allowing them to change content delivery instantaneously, while voice command technology broadens the audience as there is no contact needed to operate devices. The research investigates the ability of the platform to enhance both physically attending the class and online class activities by providing appropriate feedback, visual performance and video control, respectively. The study's preliminary results show that learning with these technologies improves comprehension and retention while encouraging active participation. This paper also discusses the concepts behind the software's design and the encompassing pedagogical strategies to ensure the successful implementation of the technology in classrooms. Future research directions are presented toward addressing how these technologies improve learning temporal metrics and their application across various scenarios in education.},
  keywords={Performance evaluation;Visualization;Learning management systems;Software design;Scalability;Education;Transforms;Real-time systems;Artificial intelligence;Augmented reality;Immersive Learning;Augmented Reality (AR);Virtual Reality (VR);Artificial Intelligence (AI);Personalized Education},
  doi={10.1109/AUTOCOM64127.2025.10957150},
  ISSN={},
  month={March},}@INPROCEEDINGS{11016866,
  author={Remolado, Alvin T. and Dumdumaya, Cristina E.},
  booktitle={2025 IEEE Open Conference of Electrical, Electronic and Information Sciences (eStream)}, 
  title={Enhancing Scholarship Allocation Through Machine Learning: A Review of Models and Techniques}, 
  year={2025},
  volume={},
  number={},
  pages={1-14},
  abstract={Scholarship allocation is essential for providing access to education, especially for students from underrepresented and economically disadvantaged backgrounds. However, traditional methods of manual and rule-based scholarship distribution often suffer from biases, inconsistencies, and inefficiencies. This systematic literature review (SLR) investigates the application of machine learning (ML) models to enhance the scholarship allocation process, addressing critical concerns regarding scalability and fairness. The review synthesizes existing research on traditional algorithms, deep learning techniques, and ensemble methods, including Random Forest, Support Vector Machines (SVM), and Gradient Boosting, while highlighting their strengths and limitations in scholarship selection. The analysis indicates that ensemble models and decision trees, such as C5.0, achieve notable accuracy, while deep learning models excel in identifying complex data patterns, albeit at the cost of significant computational resources. Additionally, effective data preprocessing techniques, such as normalization and feature engineering, are identified as vital for optimizing model performance. The study concludes with recommendations for integrating ML models into scholarship systems to promote equitable access to education, emphasizing the importance of hybrid approaches to tackle real-world challenges. This review not only consolidates current methodologies but also identifies research gaps, offering valuable insights for future studies aimed at improving the efficacy and fairness of machine learning-driven scholarship allocation.},
  keywords={Support vector machines;Deep learning;Analytical models;Scholarships;Biological system modeling;Computational modeling;Education;Data models;Resource management;Systematic literature review;Paper Review;Machine Learning;Scholarship Allocation;Higher Education Institution},
  doi={10.1109/eStream66938.2025.11016866},
  ISSN={2690-8506},
  month={April},}
