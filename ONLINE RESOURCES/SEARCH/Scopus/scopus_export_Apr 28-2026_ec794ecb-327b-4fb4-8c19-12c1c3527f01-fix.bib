@ARTICLE{Cohausz2023125,
	author = {Cohausz, Lea and Tschalzev, Andrej and Bartelt, Christian and Stuckenschmidt, Heiner},
	title = {Investigating the Importance of Demographic Features for EDM-Predictions},
	year = {2023},
	journal = {Proceedings of the International Conference on Educational Data Mining},
	pages = {125 - 136},
	doi = {10.5281/zenodo.8115647},
	url = {https://www.scopus.com/pages/publications/105023196410?origin=resultslist},
	affiliations = {University of Mannheim, Germany},
	abstract = {Demographic features are commonly used in Educational Data Mining (EDM) research to predict at-risk students. Yet, the practice of using demographic features has to be considered extremely problematic due to the data’s sensitive nature, but also because (historic and representation) biases likely exist in the training data, which leads to strong fairness concerns. At the same time and despite the frequent use, the value of demographic features for prediction accuracy remains unclear. In this paper, we systematically investigate the importance of demographic features for at risk prediction using several publicly available datasets from different countries. We find strong evidence that including demographic features does not lead to better-performing models as long as some study-related features exist, such as performance or activity data. Additionally, we show that models, nonetheless, place importance on these features when they are included in the data– although this is not necessary for accuracy. These findings, together with our discussion, strongly suggest that at-risk prediction should not include demographic features. Our code is available at: https://anonymous.4open.science/r/edm-F7D1. © 2023 Copyright is held by the author(s).},
